# ========================
# Server Configuration
# ========================
PORT=5000
NODE_ENV=development

# ========================
# MongoDB Connection
# ========================
# Use MongoDB Atlas (free tier) or local MongoDB
# Example Atlas: mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/hyper-local-delivery?retryWrites=true&w=majority
# Example Local: mongodb://localhost:27017/hyper-local-delivery
MONGO_URI=mongodb://localhost:27017/hyper-local-delivery

# ========================
# JWT Authentication
# ========================
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# ========================
# Google Maps (Frontend)
# ========================
# Get your API key from: https://console.cloud.google.com/apis/credentials
# Enable: Maps JavaScript API, Geocoding API
VITE_GOOGLE_MAPS_KEY=your_google_maps_api_key_here

# ========================
# Frontend URL (for CORS)
# ========================
CLIENT_URL=http://localhost:5173
